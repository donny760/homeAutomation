{
  "name": "powerwall-dashboard",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev --port 3000",
    "dev:all": "concurrently -n backend,frontend -c yellow,cyan \"set PYTHONIOENCODING=utf-8 && py ../server.py\" \"next dev --port 3000\"",
    "build": "next build",
    "deploy": "next build && xcopy /E /Y /I out ..\\static\\frontend && rmdir /S /Q out",
    "start": "next start"
  },
  "dependencies": {
    "chart.js": "^4.4.3",
    "chartjs-adapter-date-fns": "^3.0.0",
    "date-fns": "^3.6.0",
    "next": "^14.2.0",
    "react": "^18.3.0",
    "react-chartjs-2": "^5.2.0",
    "react-dom": "^18.3.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "concurrently": "^9.2.1",
    "typescript": "^5.5.0"
  }
}
